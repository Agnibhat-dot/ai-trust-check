{
  "ci": {
    "collect": {
      "url": [
        "http://localhost:8000/index.html",
        "http://localhost:8000/pages/tools/ai-answer-checker.html",
        "http://localhost:8000/pages/tools/deepfake-detector.html",
        "http://localhost:8000/pages/knowledge-center/index.html",
        "http://localhost:8000/pages/blog/index.html"
      ],
      "numberOfRuns": 3,
      "settings": {
        "chromeFlags": "--no-sandbox",
        "configPath": "./lighthouserc.json"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.90 }],
        "categories:accessibility": ["error", { "minScore": 0.90 }],
        "categories:best-practices": ["error", { "minScore": 0.85 }],
        "categories:seo": ["error", { "minScore": 0.85 }]
      }
    }
  }
}
